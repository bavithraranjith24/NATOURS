{
  "name": "natours",
  "version": "1.0.0",
  "description": "Landing page for natours",
  "main": "index.js",
  "author": "bavi",
  "license": "ISC",
  "scripts": {
    "watch:sass": "sass sass/main.scss css/style.css --watch",
    "compile:sass": "sass sass/main.scss css/style.comp.css",
    "concat:css": "concat -o css/style.concat.css css/icon-font.css css/style.comp.css",
    "prefix:css": "postcss css/style.concat.css --use autoprefixer -o css/style.prefix.css",
    "dev": "concurrently \"npx sass sass/main.scss css/style.css --watch\" \"npx live-server\"",
    "start": "live-server"
  },
  "dependencies": {
    "live-server": "^1.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concat": "^1.0.3",
    "concurrently": "^9.2.1",
    "postcss-cli": "^11.0.0",
    "sass": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bavithraranjith24/NATOURS.git"
  },
  "bugs": {
    "url": "https://github.com/bavithraranjith24/NATOURS/issues"
  },
  "homepage": "https://github.com/bavithraranjith24/NATOURS#readme"
}
